GEMINI_API_KEY=your_gemini_api_key_here
# Optional — use lite model if you hit 429 quota errors:
# GEMINI_MODEL=gemini-2.0-flash-lite
# Save quota: one model per chat, no auto-probe on page load (see frontend)
GEMINI_TRY_ALL_MODELS=false
GEMINI_DECISION_RETRIES=1
AUTH_SECRET=change-this-to-a-long-random-string
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Set false to run without Supabase (faster local dev; auth/diseases need DB)
DATABASE_ENABLED=true
DATABASE_CONNECT_TIMEOUT=25

# Recommended: Session pooler URI from Supabase → Project Settings → Database → Connect
# Example (replace password; special chars must be URL-encoded in the URI):
# DATABASE_URL=postgresql://postgres.YOUR_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Or separate fields (Session mode, port 5432 — not 6543 unless you know you need it)
DATABASE_HOST=aws-0-xxx.pooler.supabase.com
DATABASE_PORT=5432
DATABASE_NAME=postgres
DATABASE_USER=postgres.YOUR_PROJECT_REF
DATABASE_PASSWORD=your_database_password
