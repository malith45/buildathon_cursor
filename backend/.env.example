# Local secrets — never commit this file (backend/.env is gitignored)

# ---------- OpenAI ----------
OPENAI_API_KEY=sk-replace-me
# gpt-4o-mini is cheap (~$0.0004/triage call). Switch to gpt-4o for stronger
# reasoning. Pricing: https://openai.com/api/pricing
OPENAI_MODEL=gpt-4o-mini
OPENAI_DECISION_RETRIES=1
# false = no live OpenAI ping at server start (saves a tiny bit of usage).
# true = verifies the API key + model work each time the server boots.
OPENAI_PROBE_ON_STARTUP=false
OPENAI_TIMEOUT=30

# ---------- Server ----------
AUTH_SECRET=change-this-to-a-long-random-string
PORT=4000
CORS_ORIGIN=http://localhost:3000
# Production: comma-separated frontend URLs (Netlify + optional deploy previews)
# CORS_ORIGINS=https://your-app.netlify.app,https://deploy-preview-1--your-app.netlify.app

# ---------- Google Cloud Storage ----------
# Set false to run without GCS (decision still works; accounts/chat history off).
STORAGE_ENABLED=true
# Name of the GCS bucket (no gs:// prefix). Create with:
#   gcloud storage buckets create gs://mediassist-<your-suffix> --location=US
GCS_BUCKET=mediassist-replace-me
# Optional explicit GCP project ID (auto-detected from credentials if blank).
GCS_PROJECT=

# Choose ONE of these auth methods:
#
# A) Service-account JSON file (recommended for Windows / no gcloud CLI):
#    1. In GCP Console > IAM > Service Accounts, create one with
#       role "Storage Object Admin" on the bucket above.
#    2. Generate a JSON key and save it locally (DO NOT commit).
#    3. Put the absolute path here:
GOOGLE_APPLICATION_CREDENTIALS=
#
# B) Application Default Credentials (if you've already run
#    `gcloud auth application-default login`), leave the line above blank.
